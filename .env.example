API_PORT=8080
API_CORS_ORIGINS="*"
API_CORS_METHODS="GET,OPTIONS,PATCH,DELETE,POST,PUT"
API_CORS_HEADERS="Authorization,Content-Type,User-Agent,Accept,Accept-Encoding,lang"
API_CORS_ALLOW_CREDENTIALS=0

DATABASE_HOST="localhost"
DATABASE_PORT="5432"
DATABASE_USER="postgres"
DATABASE_PASSWORD="postgres_password"
DATABASE_DB="barbershop_management"
DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_DB}?schema=public"
DIRECT_URL="postgres://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_DB}"

JWT_SECRET=super_secret_secret
JWT_ALGORITHM=HS256

HASH_SALT_ROUNDS=10
