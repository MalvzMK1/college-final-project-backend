// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String @id @default(uuid()) @db.Uuid()
  name           String
  email          String
  hashedPassword String
  userTypeId     Int
  photoUrl       String?

  userType              UserType      @relation(fields: [userTypeId], references: [id])
  scheduledAppointments Appointment[] @relation("customer")
  ownedAppointments     Appointment[] @relation("user")

  @@map("users")
}

model UserType {
  id   Int    @id @default(autoincrement())
  name String @unique

  users User[]

  @@map("user_types")
}

model Appointment {
  id          Int      @id @default(autoincrement())
  observation String?
  dateTime    DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  customerId  String   @db.Uuid()
  barberId    String   @db.Uuid()
  statusId    Int?     @default(1) // pending

  customer User               @relation(fields: [customerId], references: [id], name: "customer")
  barber   User               @relation(fields: [barberId], references: [id], name: "user")
  status   AppointmentStatus? @relation(fields: [statusId], references: [id])

  @@map("appointments")
}

model AppointmentStatus {
  id   Int    @id @default(autoincrement())
  name String @unique

  appointments Appointment[]

  @@map("appointment_status")
}
